generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                    String                  @id @default(cuid())
  name                  String?
  email                 String?                 @unique
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime                @default(now())
  accounts              Account[]
  activities            Activity[]
  comments              Comment[]
  compositions          Composition[]
  ownedEnsembles        Ensemble[]              @relation("EnsembleOwner")
  lobbyLocations        EnsembleLobbyLocation[]
  ensembleMemberships   EnsembleMember[]
  hostedSessions        EnsembleSession[]       @relation("EnsembleSessionHost")
  ensembleTracks        EnsembleTrack[]
  following             Follow[]                @relation("follower")
  followers             Follow[]                @relation("following")
  gdprConsent           GdprConsent?
  likes                 Like[]
  notificationsSent     Notification[]          @relation("NotifActor")
  notificationsReceived Notification[]          @relation("NotifRecipient")
  profile               Profile?
  pushSubscriptions     PushSubscription[]
  sessions              Session[]
  stravaConnection      StravaConnection?
  subscription          Subscription?
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  username           String   @unique
  bio                String?
  country            String?
  musicalInterests   String[] @default([])
  styleTags          String[] @default([])
  personaName        String?
  badges             String[] @default([])
  revealedChallenges String[] @default([])
  totalActivities    Int      @default(0)
  totalDistance      Float    @default(0)
  units              String   @default("metric")
  language           String   @default("en")
  isPublic           Boolean  @default(true)
  onboardingDone     Boolean  @default(false)
  ensembleTrialUsed  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id                String           @id @default(cuid())
  userId            String
  title             String           @default("Untitled Walk")
  startedAt         DateTime
  endedAt           DateTime?
  durationSec       Int?
  distanceM         Float?
  gpsTrack          Json
  isPublic          Boolean          @default(true)
  source            ActivitySource   @default(CADENZ)
  stravaId          String?          @unique
  createdAt         DateTime         @default(now())
  ensembleSessionId String?          @unique
  ensembleSession   EnsembleSession? @relation(fields: [ensembleSessionId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments          Comment[]
  composition       Composition?
  likes             Like[]
  notifications     Notification[]

  @@index([userId, startedAt(sort: Desc)])
}

model Composition {
  id           String   @id @default(cuid())
  activityId   String   @unique
  userId       String
  startingNote String   @default("C4")
  scale        String   @default("major")
  genre        String   @default("classical")
  instrument   String   @default("piano")
  bpmAvg       Float?
  midiEvents   Json
  audioUrl     String?
  durationSec  Int?
  createdAt    DateTime @default(now())
  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String           @id @default(cuid())
  userId            String           @unique
  stripeCustomerId  String           @unique
  stripeSubId       String?          @unique
  tier              SubscriptionTier @default(FREE)
  status            String           @default("inactive")
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StravaConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  athleteId    String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  createdAt  DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  body       String
  createdAt  DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  actorId    String
  type       NotificationType
  activityId String?
  body       String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  activity   Activity?        @relation(fields: [activityId], references: [id])
  actor      User             @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  user       User             @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actorId, type, activityId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GdprConsent {
  id          String   @id @default(cuid())
  userId      String   @unique
  analytics   Boolean  @default(false)
  marketing   Boolean  @default(false)
  consentedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ensemble {
  id        String            @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime          @default(now())
  owner     User              @relation("EnsembleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   EnsembleMember[]
  sessions  EnsembleSession[]
}

model EnsembleMember {
  ensembleId String
  userId     String
  role       EnsembleRole @default(MEMBER)
  joinedAt   DateTime     @default(now())
  ensemble   Ensemble     @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([ensembleId, userId])
}

model EnsembleSession {
  id             String                  @id @default(cuid())
  ensembleId     String
  hostId         String
  status         EnsembleSessionStatus   @default(LOBBY)
  scales         String[]
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime                @default(now())
  activity       Activity?
  lobbyLocations EnsembleLobbyLocation[]
  ensemble       Ensemble                @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  host           User                    @relation("EnsembleSessionHost", fields: [hostId], references: [id], onDelete: Cascade)
  tracks         EnsembleTrack[]
}

model EnsembleTrack {
  id           String          @id @default(cuid())
  sessionId    String
  userId       String
  instrument   String
  scale        String
  startingNote String
  bpmAvg       Float?
  midiEvents   Json
  gpsPoints    Json
  submittedAt  DateTime        @default(now())
  session      EnsembleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

model EnsembleLobbyLocation {
  sessionId String
  userId    String
  lat       Float
  lng       Float
  updatedAt DateTime        @updatedAt
  session   EnsembleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

enum ActivitySource {
  CADENZ
  STRAVA
  ENSEMBLE
}

enum SubscriptionTier {
  FREE
  PRO
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
}

enum EnsembleRole {
  OWNER
  MEMBER
}

enum EnsembleSessionStatus {
  LOBBY
  ACTIVE
  COMPLETING
  COMPLETED
  CANCELLED
}
